# if use pnpm
enable-pre-post-scripts=true
public-hoist-pattern[]=*@nextui-org/*
# Prisma 7 quebra no runtime da Vercel (Cannot find module @prisma/client-runtime-utils)
# porque .prisma/client/runtime/client.js requer transitivos do prisma e eles ficam
# isolados em .pnpm/. Hoisting força disponibilidade no node_modules raiz.
public-hoist-pattern[]=@prisma/*
public-hoist-pattern[]=*prisma*
