// Opa! Suite lead capture — AccessNet
// Generated by plan: /home/lucas/.claude/plans/t-ok-entendendo-tudo-cozy-dongarra.md

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Dados do formulário (todos obrigatórios)
  nome     String
  email    String
  telefone String // E.164 canônico: +5511999999999
  endereco String

  // UTMs
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmTerm     String? @map("utm_term")
  utmContent  String? @map("utm_content")

  // Contexto de captura
  sourcePage String? @map("source_page")
  sourceCta  String? @map("source_cta")
  referrer   String?
  userAgent  String? @map("user_agent")

  // Estado da integração Opa!
  opaContatoId      String?   @map("opa_contato_id")
  opaTemplateSentId String?   @map("opa_template_sent_id")
  opaStatus         String?   @map("opa_status") // 'pending' | 'sent' | 'failed' | 'retry_scheduled'
  opaError          String?   @map("opa_error")
  opaAttempts       Int       @default(0) @map("opa_attempts")
  opaLastAttemptAt  DateTime? @map("opa_last_attempt_at") @db.Timestamptz(6)

  logs DataTransferLog[]

  @@index([telefone])
  @@index([createdAt])
  @@index([opaStatus])
  @@map("leads")
}

model DataTransferLog {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Classificação
  eventType String @map("event_type") // 'lead.submit' | 'lead.db.insert' | 'opa.contato.search' | 'opa.contato.create' | 'opa.template.send' | 'opa.webhook.received' | 'lead.retry' | 'lead.honeypot.triggered' | 'lead.submit.client_gave_up'
  direction String // 'inbound' | 'outbound' | 'internal'
  status    String // 'success' | 'error' | 'info'

  // Correlação
  leadId        String? @map("lead_id") @db.Uuid
  correlationId String? @map("correlation_id")
  lead          Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Payloads
  requestPayload  Json? @map("request_payload")
  responsePayload Json? @map("response_payload")

  httpStatus   Int?    @map("http_status")
  durationMs   Int?    @map("duration_ms")
  errorMessage String? @map("error_message")

  @@index([createdAt])
  @@index([leadId])
  @@index([eventType])
  @@index([correlationId])
  @@map("data_transfer_logs")
}
